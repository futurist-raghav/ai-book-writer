# ============================================
# AI Book Writer - Environment Configuration
# ============================================
# Copy this file to .env and fill in your values

# ============================================
# DATABASE CONFIGURATION
# ============================================
DATABASE_URL=postgresql://aibook_user:your_password@localhost:5432/aibook
# For Docker: postgresql://aibook_user:your_password@postgres:5432/aibook

# PostgreSQL credentials (for Docker Compose)
POSTGRES_USER=aibook
POSTGRES_PASSWORD=change_this_password
POSTGRES_DB=aibook

# PostgreSQL performance tuning (for docker-compose.prod.yml)
POSTGRES_MAX_CONNECTIONS=600
POSTGRES_SHARED_BUFFERS=512MB
POSTGRES_EFFECTIVE_CACHE_SIZE=1536MB
POSTGRES_WORK_MEM=4MB
POSTGRES_MAINTENANCE_WORK_MEM=128MB
POSTGRES_WAL_BUFFERS=16MB
POSTGRES_MAX_WAL_SIZE=2GB
POSTGRES_MIN_WAL_SIZE=512MB

# ============================================
# REDIS CONFIGURATION
# ============================================
REDIS_URL=redis://localhost:6379
# For Docker: redis://redis:6379

# ============================================
# AI SERVICE API KEYS
# ============================================
# Speech-to-text provider: openai or whisper_vm
PREFERRED_STT_SERVICE=whisper_vm
STT_PROVIDER=whisper_vm
WHISPER_TIMEOUT_SECONDS=3600
WHISPER_VM_BASE_URL=http://35.200.193.248:9000
WHISPER_VM_MODEL_NAME=large-v3
WHISPER_VM_DEFAULT_TASK=transcribe
WHISPER_VM_OUTPUT_FORMAT=json
WHISPER_VM_ENCODE=true
WHISPER_VM_WORD_TIMESTAMPS=false

# Optional fallback when STT_PROVIDER=openai
OPENAI_API_KEY=sk-your-openai-api-key-here

# Google AI Studio (for Gemini)
GOOGLE_GEMINI_API_KEY_1=your-google-ai-api-key-1
GOOGLE_GEMINI_API_KEY_2=your-google-ai-api-key-2
GOOGLE_GEMINI_API_KEY_3=your-google-ai-api-key-3
GOOGLE_GEMINI_MODEL=gemini-3-flash-preview
# Backward-compatible single key (optional)
GOOGLE_AI_API_KEY=your-google-ai-api-key

# Anthropic (for Claude - optional)
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key-here

# ============================================
# APPLICATION CONFIGURATION
# ============================================
# Secret key for JWT tokens (generate with: openssl rand -hex 32)
SECRET_KEY=your-secret-key-here-generate-with-openssl-rand

# Environment: development, staging, production
ENVIRONMENT=development

# Debug mode (set to False in production)
DEBUG=True

# Backend web concurrency (for docker-compose.prod.yml)
WEB_CONCURRENCY=4
UVICORN_TIMEOUT=120
UVICORN_GRACEFUL_TIMEOUT=30
UVICORN_KEEPALIVE=5
GUNICORN_MAX_REQUESTS=2000
GUNICORN_MAX_REQUESTS_JITTER=200

# SQLAlchemy async pool tuning
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=40
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800
DB_STATEMENT_TIMEOUT_MS=30000

# Celery worker tuning
CELERY_CONCURRENCY=8
CELERY_PREFETCH_MULTIPLIER=4

# Allowed CORS origins (comma-separated)
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:3001,http://127.0.0.1:3001,capacitor://localhost,ionic://localhost

# ============================================
# STORAGE CONFIGURATION
# ============================================
# Storage backend: local, gcs, s3
STORAGE_BACKEND=local

# Local storage path (for local backend)
LOCAL_STORAGE_PATH=./storage

# Google Cloud Storage (if using GCS)
GCS_BUCKET_NAME=your-gcs-bucket-name
GCS_PROJECT_ID=your-gcp-project-id

# AWS S3 (if using S3)
AWS_S3_BUCKET=your-s3-bucket-name
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=us-east-1

# ============================================
# CELERY CONFIGURATION
# ============================================
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# ============================================
# VECTOR DATABASE (ChromaDB)
# ============================================
CHROMA_PERSIST_DIRECTORY=./chroma_data
CHROMA_HOST=localhost
CHROMA_PORT=8001

# ============================================
# LOGGING CONFIGURATION
# ============================================
LOG_LEVEL=INFO
# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL

# ============================================
# FRONTEND CONFIGURATION
# ============================================
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_WS_URL=ws://localhost:1000/ws

# ============================================
# EMAIL CONFIGURATION (Optional)
# ============================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=noreply@aibook.com

# ============================================
# MONITORING & ANALYTICS (Optional)
# ============================================
SENTRY_DSN=your-sentry-dsn-here
POSTHOG_API_KEY=your-posthog-api-key

# ============================================
# RATE LIMITING
# ============================================
RATE_LIMIT_PER_HOUR=100
RATE_LIMIT_BURST=20

# ============================================
# FILE UPLOAD LIMITS
# ============================================
MAX_UPLOAD_SIZE_MB=500
ALLOWED_AUDIO_FORMATS=mp3,wav,m4a,ogg,flac

# ============================================
# AI PROCESSING CONFIGURATION
# ============================================
# Preferred STT service: openai, whisper_vm
PREFERRED_STT_SERVICE=whisper_vm

# Preferred LLM service: google, anthropic, openai
PREFERRED_LLM_SERVICE=google

# Max audio duration in minutes
MAX_AUDIO_DURATION_MINUTES=180

# Enable user API keys (allow users to bring their own keys)
ENABLE_USER_API_KEYS=True
