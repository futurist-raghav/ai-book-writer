# ============================================
# AI Book Writer - Environment Configuration
# ============================================
# Copy this file to .env and fill in your values

# ============================================
# DATABASE CONFIGURATION
# ============================================
DATABASE_URL=postgresql://aibook_user:your_password@localhost:5432/aibook
# For Docker: postgresql://aibook_user:your_password@postgres:5432/aibook

# PostgreSQL credentials (for Docker Compose)
POSTGRES_USER=aibook
POSTGRES_PASSWORD=change_this_password
POSTGRES_DB=aibook

# ============================================
# REDIS CONFIGURATION
# ============================================
REDIS_URL=redis://localhost:6379
# For Docker: redis://redis:6379

# ============================================
# AI SERVICE API KEYS
# ============================================
# OpenAI (for Whisper speech-to-text)
OPENAI_API_KEY=sk-your-openai-api-key-here

# Google AI Studio (for Gemini)
GOOGLE_AI_API_KEY=your-google-ai-api-key-here

# Anthropic (for Claude - optional)
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key-here

# ============================================
# APPLICATION CONFIGURATION
# ============================================
# Secret key for JWT tokens (generate with: openssl rand -hex 32)
SECRET_KEY=your-secret-key-here-generate-with-openssl-rand

# Environment: development, staging, production
ENVIRONMENT=development

# Debug mode (set to False in production)
DEBUG=True

# Allowed CORS origins (comma-separated)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# ============================================
# STORAGE CONFIGURATION
# ============================================
# Storage backend: local, gcs, s3
STORAGE_BACKEND=local

# Local storage path (for local backend)
LOCAL_STORAGE_PATH=./storage

# Google Cloud Storage (if using GCS)
GCS_BUCKET_NAME=your-gcs-bucket-name
GCS_PROJECT_ID=your-gcp-project-id

# AWS S3 (if using S3)
AWS_S3_BUCKET=your-s3-bucket-name
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=us-east-1

# ============================================
# CELERY CONFIGURATION
# ============================================
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# ============================================
# VECTOR DATABASE (ChromaDB)
# ============================================
CHROMA_PERSIST_DIRECTORY=./chroma_data
CHROMA_HOST=localhost
CHROMA_PORT=8001

# ============================================
# LOGGING CONFIGURATION
# ============================================
LOG_LEVEL=INFO
# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL

# ============================================
# FRONTEND CONFIGURATION
# ============================================
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_WS_URL=ws://localhost:1000/ws

# ============================================
# EMAIL CONFIGURATION (Optional)
# ============================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=noreply@aibook.com

# ============================================
# MONITORING & ANALYTICS (Optional)
# ============================================
SENTRY_DSN=your-sentry-dsn-here
POSTHOG_API_KEY=your-posthog-api-key

# ============================================
# RATE LIMITING
# ============================================
RATE_LIMIT_PER_HOUR=100
RATE_LIMIT_BURST=20

# ============================================
# FILE UPLOAD LIMITS
# ============================================
MAX_UPLOAD_SIZE_MB=500
ALLOWED_AUDIO_FORMATS=mp3,wav,m4a,ogg,flac

# ============================================
# AI PROCESSING CONFIGURATION
# ============================================
# Preferred STT service: openai, google
PREFERRED_STT_SERVICE=openai

# Preferred LLM service: google, anthropic, openai
PREFERRED_LLM_SERVICE=google

# Max audio duration in minutes
MAX_AUDIO_DURATION_MINUTES=180

# Enable user API keys (allow users to bring their own keys)
ENABLE_USER_API_KEYS=True
