# Frontend Environment Variables

# API URL (Backend)
# For local development:
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1

# For VM deployment (update VM_IP with your actual VM external IP):
# NEXT_PUBLIC_API_URL=http://VM_IP:8000/api/v1

# For production with custom domain:
# NEXT_PUBLIC_API_URL=https://api.scribehouse.raghavagarwal.com/api/v1

# App Configuration
NEXT_PUBLIC_APP_NAME=Scribe House
NEXT_PUBLIC_APP_URL=http://localhost:3000
