# Application Settings
APP_NAME=Scribe House
VERSION=1.1.0
ENVIRONMENT=development
DEBUG=true
SECRET_KEY=your-super-secret-key-change-in-production

# API Configuration
API_V1_PREFIX=/api/v1

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:3001,http://127.0.0.1:3001,capacitor://localhost,ionic://localhost

# Database
DATABASE_URL=postgresql://aibook_user:password@localhost:5432/aibook
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=40
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800
DB_STATEMENT_TIMEOUT_MS=30000

# Redis
REDIS_URL=redis://localhost:6379

# Celery
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# JWT Authentication
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# AI Service API Keys
# STT provider: openai or whisper_vm
PREFERRED_STT_SERVICE=whisper_vm
STT_PROVIDER=whisper_vm
WHISPER_TIMEOUT_SECONDS=3600
WHISPER_VM_BASE_URL=http://35.200.193.248:9000
WHISPER_VM_MODEL_NAME=large-v3
WHISPER_VM_DEFAULT_TASK=transcribe
WHISPER_VM_OUTPUT_FORMAT=json
WHISPER_VM_ENCODE=true
WHISPER_VM_WORD_TIMESTAMPS=false

# Optional fallback when STT_PROVIDER=openai
OPENAI_API_KEY=your-openai-api-key
GOOGLE_GEMINI_API_KEY_1=your-google-ai-api-key-1
GOOGLE_GEMINI_API_KEY_2=your-google-ai-api-key-2
GOOGLE_GEMINI_API_KEY_3=your-google-ai-api-key-3
GOOGLE_GEMINI_MODEL=gemini-3-flash-preview
# Backward-compatible single key (optional)
GOOGLE_AI_API_KEY=your-google-ai-api-key
ANTHROPIC_API_KEY=your-anthropic-api-key

# Storage Settings
STORAGE_BACKEND=local
LOCAL_STORAGE_PATH=./storage

# Google Cloud Storage (optional)
# GCS_BUCKET_NAME=your-bucket-name
# GCS_PROJECT_ID=your-project-id

# AWS S3 (optional)
# AWS_S3_BUCKET=your-bucket-name
# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key
# AWS_REGION=us-east-1

# ChromaDB
CHROMA_PERSIST_DIRECTORY=./chroma_data
CHROMA_HOST=localhost
CHROMA_PORT=8001

# Logging
LOG_LEVEL=INFO

# Production web runtime
WEB_CONCURRENCY=4
UVICORN_TIMEOUT=120
UVICORN_GRACEFUL_TIMEOUT=30
UVICORN_KEEPALIVE=5

# File Upload Limits
MAX_AUDIO_FILE_SIZE_MB=500
ALLOWED_AUDIO_FORMATS=mp3,wav,m4a,flac,ogg,webm
