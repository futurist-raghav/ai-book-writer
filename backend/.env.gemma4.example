# Gemma 4 STT Configuration Example

# ===== STT Provider Configuration =====
# Choose one of: openai, whisper_vm, gemma4
STT_PROVIDER=gemma4
PREFERRED_STT_SERVICE=gemma4

# ===== Gemma 4 Service Configuration =====
# Base URL for Ollama service (self-hosted)
# Default: http://localhost:11434 (local machine)
# For Docker: http://ollama:11434 (service name)
# For VM: http://[VM_IP]:11434
GEMMA4_BASE_URL=http://localhost:11434

# Model name to use for Gemma 4
# Options: gemma4:7b, gemma4:e4b (recommended), gemma4:13b, gemma4:latest
GEMMA4_MODEL=gemma4:e4b

# Request timeout in seconds (for transcription requests)
# Increase for longer audio files or slower hardware
GEMMA4_TIMEOUT_SECONDS=300

# Sampling temperature (0.0 = deterministic, 1.0 = maximum randomness)
# Recommended: 0.3 for transcription (low variance)
GEMMA4_TEMPERATURE=0.3

# Nucleus sampling threshold (0.0-1.0)
# Controls diversity of output. Lower = more focused.
GEMMA4_TOP_P=0.9

# Maximum number of tokens in response
# Increase for longer transcriptions, decrease for faster processing
GEMMA4_MAX_TOKENS=4096

# ===== Fallback to Whisper Configuration (if Gemma4 fails) =====
# OpenAI Whisper API key (optional fallback)
# OPENAI_API_KEY=sk-...

# Self-hosted Whisper configuration (optional fallback)
# WHISPER_VM_BASE_URL=http://localhost:8000
# WHISPER_VM_MODEL_NAME=large-v3
# WHISPER_VM_OUTPUT_FORMAT=json
# WHISPER_VM_WORD_TIMESTAMPS=true

# ===== Health Check and Monitoring =====
# Enable Gemma 4 health checks
GEMMA4_HEALTH_CHECK_ENABLED=true

# Health check interval (seconds)
GEMMA4_HEALTH_CHECK_INTERVAL=300

